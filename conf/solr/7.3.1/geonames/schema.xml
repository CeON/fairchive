<?xml version="1.0" encoding="UTF-8" ?>
<schema name="default-config" version="1.6">
    <!-- GeoName fields -->
    <field name="id" type="string" required="true"/>
    <uniqueKey>id</uniqueKey>
    <field name="name" type="cace_insensitive_text" required="true"/>
    <field name="alternateNames" type="cace_insensitive_text"/>
    <field name="featureCode" type="string" indexed="true"/>
    <field name="hierarchy" type="string" indexed="false" required="true"/>
    <!-- fields required by Solr -->
    <field name="_version_" type="plong" indexed="false" stored="false"/>
    
    <!-- field types -->
    <fieldType name="string" class="solr.StrField"/>
    <fieldType name="plong" class="solr.LongPointField" docValues="true"/>
    <!-- we want querries to be case insensitive -->
    <fieldType name="cace_insensitive_text" class="solr.TextField" 
               omitTermFreqAndPositions="true">
        <analyzer type="index">
            <tokenizer class="solr.StandardTokenizerFactory" />
            <filter class="solr.LowerCaseFilterFactory" />
        </analyzer>
        <analyzer type="query">
            <tokenizer class="solr.StandardTokenizerFactory" />
            <filter class="solr.LowerCaseFilterFactory" />
        </analyzer>
    </fieldType>
</schema>
